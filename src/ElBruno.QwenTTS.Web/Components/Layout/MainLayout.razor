@inherits LayoutComponentBase

<div class="page">
    <div class="app-top-bar">
        <div class="top-bar-brand"><span>🔊</span> Qwen TTS</div>
        <div class="top-bar-actions">
            <a href="/" class="nav-pill">🔊 TTS</a>
            <a href="/voice-clone" class="nav-pill">🎭 Voice Clone</a>
            <span class="nav-sep"></span>
            <button class="theme-btn" onclick="setTheme('light')">☀️</button>
            <button class="theme-btn" onclick="setTheme('system')">💻</button>
            <button class="theme-btn" onclick="setTheme('dark')">🌙</button>
        </div>
    </div>
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
