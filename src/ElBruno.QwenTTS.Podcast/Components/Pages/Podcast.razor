@page "/"
@using ElBruno.QwenTTS.Podcast.Services
@using ElBruno.QwenTTS.Pipeline
@inject TtsPipelineService Tts
@inject IJSRuntime JS
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Podcast Generator — Qwen TTS</PageTitle>

<div class="main-content">
    <!-- Model Status Banner -->
    @if (!Tts.IsReady)
    {
        <div class="tts-card" style="border-left:4px solid var(--accent);">
            @if (_downloadProgress != null)
            {
                <h3>⬇️ Downloading Model</h3>
                <div class="progress-bar-track" style="margin-bottom:0.5rem;">
                    <div class="progress-bar-fill" style="width:@(_downloadProgress.FilePercentage)%"></div>
                </div>
                <div style="font-size:0.82rem;color:var(--text-muted);">
                    [@_downloadProgress.CurrentFile/@_downloadProgress.TotalFiles] @_downloadProgress.Message
                </div>
            }
            else if (_initError != null)
            {
                <h3>⚠️ Model Error</h3>
                <div style="color:var(--red);font-size:0.88rem;">@_initError</div>
                <button class="btn btn-sm btn-primary mt-2" @onclick="InitializeModel">Retry</button>
            }
            else
            {
                <h3>⏳ Loading Model...</h3>
                <div style="font-size:0.82rem;color:var(--text-muted);">
                    @if (Tts.IsModelDownloaded)
                    {
                        <span>Model files found — loading ONNX sessions...</span>
                    }
                    else
                    {
                        <span>Preparing to download model from HuggingFace (~5.5 GB)...</span>
                    }
                </div>
            }
        </div>
    }

    <!-- Upload + Generate (side by side) -->
    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:stretch;">
        <div class="tts-card" style="flex:1;min-width:280px;">
            <h3>📄 Upload Podcast Script</h3>
            <p style="color:var(--text-muted);font-size:0.82rem;margin-bottom:0.75rem;">
                Upload a <code>.txt</code> or <code>.md</code> file with segments delimited by <code>--- NN</code> or <code>## Segment NN</code>.
                <a href="/samples" style="color:var(--blue);">See prompt templates</a>
            </p>
            <InputFile class="form-control" OnChange="OnFileSelected" accept=".txt,.md" />
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger mt-2">⚠️ @_error</div>
            }
        </div>
        @if (_segments.Count > 0)
        {
            <div class="tts-card" style="display:flex;flex-direction:column;justify-content:center;gap:0.5rem;min-width:200px;">
                <button class="btn btn-primary generate-btn" @onclick="GenerateAsync" disabled="@(_generating || !Tts.IsReady || SelectedCount == 0)">
                    @if (_generating)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Generating...</span>
                    }
                    else
                    {
                        <span>🎙️ Generate (@SelectedCount segments)</span>
                    }
                </button>
                @if (_generating)
                {
                    <button class="btn btn-outline-danger" @onclick="StopGeneration">🛑 Stop</button>
                }
            </div>
        }
    </div>

    <!-- Progress Bar (between upload and segment table, visible during generation) -->
    @if (_generating || _progressPct == 100)
    {
        <div class="tts-card" style="padding:0.6rem 0.85rem;">
            <div class="progress-bar-track">
                <div class="progress-bar-fill" style="width:@(_progressPct)%"></div>
            </div>
            <div class="progress-label">
                <span>@_progressStatus</span>
                <span>
                    @_completedCount / @(_selectedSegments?.Count ?? 0)
                    <span style="margin-left:0.5rem;">⏱ @FormatElapsed(_elapsed)</span>
                    @if (_estimatedRemaining != null)
                    {
                        <span style="margin-left:0.5rem;color:var(--text-dim);">~@FormatElapsed(_estimatedRemaining.Value) left</span>
                    }
                </span>
            </div>
        </div>
    }

    <!-- Segment Preview Table -->
    @if (_segments.Count > 0)
    {
        <div class="tts-card">
            <h3>📋 Episode Preview — @_segments.Count Segments (@SelectedCount selected)</h3>
            <div id="segmentTableContainer" style="max-height:300px;overflow-y:auto;">
                <table class="segment-table">
                    <thead>
                        <tr>
                            <th style="width:36px;text-align:center;">
                                <input type="checkbox" checked="@_allSelected" @onchange="ToggleSelectAll" />
                            </th>
                            <th>#</th>
                            <th>Speaker</th>
                            <th>Lang</th>
                            <th>Text</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var seg in _segments)
                        {
                            <tr class="@SegmentRowClass(seg)" id="seg-row-@seg.Number">
                                <td style="text-align:center;">
                                    <input type="checkbox" checked="@seg.Selected" @onchange="() => seg.Selected = !seg.Selected" disabled="@_generating" />
                                </td>
                                <td>@seg.Number</td>
                                <td><span class="speaker-badge">@seg.Speaker</span></td>
                                <td>@seg.Language</td>
                                <td class="text-preview">@Truncate(seg.Text, 80)</td>
                                <td>
                                    @switch (seg.Status)
                                    {
                                        case SegStatus.Pending:
                                            <span style="color:var(--text-dim)">⏳</span>
                                            break;
                                        case SegStatus.Generating:
                                            <span class="spinner-border spinner-border-sm" style="color:var(--accent);width:14px;height:14px;"></span>
                                            break;
                                        case SegStatus.Done:
                                            <span style="color:var(--green)">✔ @(seg.Duration > 0 ? $"{seg.Duration:F1}s" : "")</span>
                                            break;
                                        case SegStatus.Error:
                                            <span style="color:var(--red)">✘ @(seg.Retries > 0 ? $"(retry {seg.Retries}/3)" : "")</span>
                                            break;
                                        case SegStatus.Skipped:
                                            <span style="color:var(--text-dim)">—</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Results -->
    @if (_completed && _mergedUrl != null)
    {
        <div class="tts-card" style="margin-top:0.75rem;">
            <h3>🎵 Episode Ready</h3>
            <audio id="episodePlayer" controls src="@_mergedUrl" preload="auto" style="width:100%;height:40px;border-radius:6px;"></audio>
            <div class="download-all-bar" style="padding-top:0.75rem;display:flex;gap:0.5rem;flex-wrap:wrap;">
                <a href="@_mergedUrl" download="podcast_episode.wav" class="download-all-btn">
                    ⬇ Download Full Episode (.wav)
                </a>
                @if (_zipUrl != null)
                {
                    <a href="@_zipUrl" download="podcast_segments.zip" class="download-all-btn" style="background:var(--bg-hover);">
                        📦 Download All Segments (.zip)
                    </a>
                }
            </div>

            <!-- Collapsed individual segments -->
            <details style="margin-top:1rem;">
                <summary style="color:var(--text-muted);font-size:0.8rem;cursor:pointer;">
                    Show individual segments (@_segmentUrls.Count(u => !string.IsNullOrEmpty(u)) files)
                </summary>
                <div style="margin-top:0.5rem;">
                    @for (int i = 0; i < _segmentUrls.Count; i++)
                    {
                        var seg = _segments[i];
                        var url = _segmentUrls[i];
                        @if (!string.IsNullOrEmpty(url))
                        {
                            <div class="audio-result-card">
                                <audio controls src="@url" preload="none"></audio>
                                <div class="audio-meta">
                                    <span class="label">@seg.Number. @seg.Speaker</span>
                                    <a href="@url" download="podcast_@(seg.Number)_@(seg.Speaker).wav" class="download-btn">⬇ WAV</a>
                                </div>
                            </div>
                        }
                    }
                </div>
            </details>
        </div>
    }
</div>

<!-- Docked Console -->
<div class="console-dock @(_consoleExpanded ? "expanded" : "collapsed")">
    <div class="console-header" @onclick="() => _consoleExpanded = !_consoleExpanded">
        <span><span class="dot @(_generating ? "active" : "")"></span> Console (@_logs.Count)</span>
        <div class="console-header-actions">
            <button @onclick="() => _logs.Clear()" @onclick:stopPropagation="true">Clear</button>
            <button>@(_consoleExpanded ? "▼" : "▲")</button>
        </div>
    </div>
    @if (_consoleExpanded)
    {
        <div class="console-body" id="podcastConsole">
            @if (_logs.Count == 0)
            {
                <div class="log-line"><span class="ts">--:--:--</span><span class="msg" style="color:var(--text-dim)">Upload a podcast script to begin...</span></div>
            }
            @foreach (var log in _logs)
            {
                <div class="log-line @log.Level">
                    <span class="ts">@log.Time</span>
                    <span class="msg">@log.Message</span>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PodcastSegment> _segments = new();
    private List<PodcastSegment> _selectedSegments = new();
    private List<string> _segmentUrls = new();
    private string? _mergedUrl;
    private string? _zipUrl;
    private string? _error;
    private bool _generating;
    private bool _completed;
    private bool _stopRequested;
    private bool _consoleExpanded = true;
    private int _completedCount;
    private int _progressPct;
    private string _progressStatus = "";
    private List<LogEntry> _logs = new();
    private TimeSpan _elapsed;
    private TimeSpan? _estimatedRemaining;
    private System.Timers.Timer? _elapsedTimer;
    private System.Diagnostics.Stopwatch? _stopwatch;
    private const int MaxRetries = 3;
    private ModelDownloadProgress? _downloadProgress;
    private string? _initError;

    private int SelectedCount => _segments.Count(s => s.Selected);
    private bool _allSelected => _segments.Count > 0 && _segments.All(s => s.Selected);

    protected override async Task OnInitializedAsync()
    {
        Tts.OnDownloadProgress += OnDownloadProgressUpdate;
        await InitializeModel();
    }

    public void Dispose()
    {
        Tts.OnDownloadProgress -= OnDownloadProgressUpdate;
        _elapsedTimer?.Stop();
        _elapsedTimer?.Dispose();
    }

    private async Task InitializeModel()
    {
        _initError = null;
        _downloadProgress = null;
        StateHasChanged();

        try
        {
            await Tts.InitializeAsync();
            Log("Model loaded and ready", "success");
        }
        catch (Exception ex)
        {
            _initError = ex.Message;
            Log($"Model initialization failed: {ex.Message}", "error");
        }
        StateHasChanged();
    }

    private void OnDownloadProgressUpdate(ModelDownloadProgress progress)
    {
        InvokeAsync(() =>
        {
            _downloadProgress = progress;
            StateHasChanged();
        });
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var val = (bool)(e.Value ?? false);
        foreach (var seg in _segments) seg.Selected = val;
    }

    private void StopGeneration()
    {
        _stopRequested = true;
        Log("Stop requested — will stop after current segment completes", "step");
    }

    private void Log(string msg, string level = "info")
    {
        _logs.Add(new LogEntry(DateTime.Now.ToString("HH:mm:ss"), msg, level));
        if (_logs.Count > 300) _logs.RemoveAt(0);
    }

    private async Task ScrollConsole() =>
        await JS.InvokeVoidAsync("eval", "document.getElementById('podcastConsole')?.scrollTo(0,999999)");

    private async Task ScrollToSegment(string number) =>
        await JS.InvokeVoidAsync("eval", $"document.getElementById('seg-row-{number}')?.scrollIntoView({{behavior:'smooth',block:'center'}})");

    private static string FormatElapsed(TimeSpan ts) =>
        ts.TotalHours >= 1 ? ts.ToString(@"h\:mm\:ss") : ts.ToString(@"m\:ss");

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        _segments.Clear();
        _segmentUrls.Clear();
        _mergedUrl = null;
        _zipUrl = null;
        _completed = false;

        var file = e.File;
        if (file.Size > 1_000_000) { _error = "File too large (max 1 MB)."; return; }

        using var reader = new StreamReader(file.OpenReadStream(maxAllowedSize: 1_000_000));
        var content = await reader.ReadToEndAsync();

        Log($"Loaded: {file.Name} ({file.Size:N0} bytes)", "info");

        _segments = ParsePodcastScript(content);

        if (_segments.Count == 0)
        {
            _error = "No valid segments found. Use '--- NN' or '## Segment NN' delimiters with speaker and text fields.";
            Log("Parse failed: no segments found", "error");
        }
        else
        {
            Log($"Parsed {_segments.Count} segments with {_segments.Select(s => s.Speaker).Distinct().Count()} unique speakers", "success");
        }
        StateHasChanged();
        await ScrollConsole();
    }

    private async Task GenerateAsync()
    {
        _generating = true;
        _completed = false;
        _stopRequested = false;
        _completedCount = 0;
        _progressPct = 0;
        _segmentUrls.Clear();
        _mergedUrl = null;
        _zipUrl = null;
        _error = null;
        _elapsed = TimeSpan.Zero;
        _estimatedRemaining = null;

        // Build selected segments list
        _selectedSegments = _segments.Where(s => s.Selected).ToList();
        foreach (var s in _segments)
        {
            s.Duration = 0;
            s.Retries = 0;
            s.Status = s.Selected ? SegStatus.Pending : SegStatus.Skipped;
        }
        StateHasChanged();

        _stopwatch = System.Diagnostics.Stopwatch.StartNew();
        _elapsedTimer = new System.Timers.Timer(1000);
        _elapsedTimer.Elapsed += (_, _) => InvokeAsync(() =>
        {
            _elapsed = _stopwatch.Elapsed;
            if (_completedCount > 0)
            {
                var avgPerSeg = _elapsed.TotalSeconds / _completedCount;
                var remaining = avgPerSeg * (_selectedSegments.Count - _completedCount);
                _estimatedRemaining = TimeSpan.FromSeconds(remaining);
            }
            StateHasChanged();
        });
        _elapsedTimer.Start();

        Log($"Starting podcast generation: {_selectedSegments.Count} of {_segments.Count} segments selected", "step");
        StateHasChanged();
        await ScrollConsole();

        // Initialize URL slots for ALL segments (keeps index alignment)
        for (int i = 0; i < _segments.Count; i++)
            _segmentUrls.Add("");

        try
        {
            for (int si = 0; si < _selectedSegments.Count; si++)
            {
                if (_stopRequested)
                {
                    Log("Generation stopped by user", "step");
                    break;
                }

                var seg = _selectedSegments[si];
                var globalIndex = _segments.IndexOf(seg);
                var success = false;

                for (int attempt = 0; attempt <= MaxRetries && !success; attempt++)
                {
                    if (_stopRequested) break;

                    if (attempt > 0)
                    {
                        seg.Retries = attempt;
                        Log($"Retrying segment {seg.Number} (attempt {attempt + 1}/{MaxRetries + 1})...", "step");
                    }

                    seg.Status = SegStatus.Generating;
                    _progressStatus = $"Segment {seg.Number}: {seg.Speaker} — {Truncate(seg.Text, 40)}";
                    if (attempt == 0)
                        Log($"[{si + 1}/{_selectedSegments.Count}] {seg.Speaker}: \"{Truncate(seg.Text, 50)}\"", "step");
                    StateHasChanged();
                    await ScrollToSegment(seg.Number);
                    await ScrollConsole();

                    var progress = new Progress<string>(msg =>
                    {
                        InvokeAsync(() => { Log(msg); StateHasChanged(); ScrollConsole(); });
                    });

                    try
                    {
                        var segSw = System.Diagnostics.Stopwatch.StartNew();
                        var url = await Tts.GenerateAsync(seg.Text, seg.Speaker, seg.Language, seg.Instructions, progress);
                        segSw.Stop();

                        _segmentUrls[globalIndex] = url;
                        seg.Status = SegStatus.Done;
                        seg.Duration = segSw.Elapsed.TotalSeconds;
                        Log($"Segment {seg.Number} done ({segSw.Elapsed.TotalSeconds:F1}s)", "success");
                        success = true;
                    }
                    catch (Exception ex)
                    {
                        Log($"Segment {seg.Number} failed: {ex.Message}", "error");
                        if (attempt >= MaxRetries)
                        {
                            seg.Status = SegStatus.Error;
                            Log($"Segment {seg.Number} failed after {MaxRetries + 1} attempts, skipping", "error");
                        }
                        else
                        {
                            await Task.Delay(500);
                        }
                    }
                }

                _completedCount = si + 1;
                _progressPct = (int)((_completedCount) * 100.0 / _selectedSegments.Count);
                StateHasChanged();
                await ScrollConsole();
            }

            if (!_stopRequested)
            {
                // Merge with silence gaps
                Log("Merging segments with 0.5s silence gaps...", "step");
                StateHasChanged();
                await ScrollConsole();

                var validUrls = _segmentUrls.Where(u => !string.IsNullOrEmpty(u)).ToList();
                _mergedUrl = await Tts.MergeWavFilesAsync(validUrls, silenceMs: 500);

                // Create zip of individual segments
                Log("Creating zip archive of individual segments...", "step");
                StateHasChanged();
                _zipUrl = await Tts.CreateSegmentZipAsync(_segmentUrls, _segments.Select(s => $"podcast_{s.Number}_{s.Speaker}.wav").ToList());

                _completed = true;
                Log($"Episode ready! {validUrls.Count} segments merged in {_stopwatch.Elapsed.TotalSeconds:F1}s total", "success");
            }

            _stopwatch.Stop();
            _elapsedTimer.Stop();
            _elapsed = _stopwatch.Elapsed;
            _estimatedRemaining = null;
            _progressStatus = _stopRequested ? "Stopped" : "Complete!";
            _progressPct = _stopRequested ? _progressPct : 100;
            StateHasChanged();

            if (_completed)
            {
                await Task.Delay(100);
                await JS.InvokeVoidAsync("eval", "document.getElementById('episodePlayer')?.play()");
            }
        }
        catch (Exception ex)
        {
            _error = $"Generation failed: {ex.Message}";
            Log($"ERROR: {ex.Message}", "error");
        }
        finally
        {
            _generating = false;
            _stopRequested = false;
            _elapsedTimer?.Stop();
            _elapsedTimer?.Dispose();
            StateHasChanged();
            await ScrollConsole();
        }
    }

    private static List<PodcastSegment> ParsePodcastScript(string content)
    {
        if (System.Text.RegularExpressions.Regex.IsMatch(content, @"^##\s+Segmento?\s+\d+", System.Text.RegularExpressions.RegexOptions.Multiline))
            return ParseMarkdownFormat(content);
        return ParseDelimiterFormat(content);
    }

    private static List<PodcastSegment> ParseDelimiterFormat(string content)
    {
        var segments = new List<PodcastSegment>();
        var parts = System.Text.RegularExpressions.Regex.Split(content, @"^---\s+(\d+)\s*$", System.Text.RegularExpressions.RegexOptions.Multiline);

        for (int i = 1; i + 1 < parts.Length; i += 2)
        {
            var number = parts[i].Trim();
            var block = parts[i + 1];
            var seg = ParseSegmentBlock(number, block);
            if (seg != null) segments.Add(seg);
        }
        return segments;
    }

    private static List<PodcastSegment> ParseMarkdownFormat(string content)
    {
        var segments = new List<PodcastSegment>();
        var parts = System.Text.RegularExpressions.Regex.Split(content, @"^##\s+Segmento?\s+(\d+)\s*$", System.Text.RegularExpressions.RegexOptions.Multiline);

        for (int i = 1; i + 1 < parts.Length; i += 2)
        {
            var number = parts[i].Trim();
            var block = parts[i + 1];

            var seg = new PodcastSegment { Number = number };
            var speakerMatch = System.Text.RegularExpressions.Regex.Match(block, @"\*\*Speaker:\*\*\s*(.+)$", System.Text.RegularExpressions.RegexOptions.Multiline | System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            var langMatch = System.Text.RegularExpressions.Regex.Match(block, @"\*\*Language:\*\*\s*(.+)$", System.Text.RegularExpressions.RegexOptions.Multiline | System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            var instrMatch = System.Text.RegularExpressions.Regex.Match(block, @"\*\*Instructions:\*\*\s*(.+)$", System.Text.RegularExpressions.RegexOptions.Multiline | System.Text.RegularExpressions.RegexOptions.IgnoreCase);

            if (speakerMatch.Success) seg.Speaker = speakerMatch.Groups[1].Value.Trim();
            if (langMatch.Success) seg.Language = langMatch.Groups[1].Value.Trim();
            if (instrMatch.Success) seg.Instructions = instrMatch.Groups[1].Value.Trim();

            var lastMeta = new[] { speakerMatch, langMatch, instrMatch }.Where(m => m.Success).MaxBy(m => m.Index + m.Length);
            if (lastMeta != null)
                seg.Text = block[(lastMeta.Index + lastMeta.Length)..].Trim();

            if (!string.IsNullOrWhiteSpace(seg.Text) && !string.IsNullOrWhiteSpace(seg.Speaker))
                segments.Add(seg);
        }
        return segments;
    }

    private static PodcastSegment? ParseSegmentBlock(string number, string block)
    {
        var seg = new PodcastSegment { Number = number };

        var speakerMatch = System.Text.RegularExpressions.Regex.Match(block, @"^speaker:\s*(.+)$", System.Text.RegularExpressions.RegexOptions.Multiline);
        var langMatch = System.Text.RegularExpressions.Regex.Match(block, @"^language:\s*(.+)$", System.Text.RegularExpressions.RegexOptions.Multiline);
        var instrMatch = System.Text.RegularExpressions.Regex.Match(block, @"^instructions:\s*(.+)$", System.Text.RegularExpressions.RegexOptions.Multiline);
        var textMatch = System.Text.RegularExpressions.Regex.Match(block, @"^text:\s*(.+(?:\n(?!speaker:|language:|instructions:|---\s).*)*)", System.Text.RegularExpressions.RegexOptions.Multiline);

        if (speakerMatch.Success) seg.Speaker = speakerMatch.Groups[1].Value.Trim();
        if (langMatch.Success) seg.Language = langMatch.Groups[1].Value.Trim();
        if (instrMatch.Success) seg.Instructions = instrMatch.Groups[1].Value.Trim();

        if (textMatch.Success)
        {
            seg.Text = textMatch.Groups[1].Value.Trim();
        }
        else
        {
            var lastMeta = new[] { speakerMatch, langMatch, instrMatch }.Where(m => m.Success).MaxBy(m => m.Index + m.Length);
            if (lastMeta != null)
                seg.Text = block[(lastMeta.Index + lastMeta.Length)..].Trim();
        }

        if (!string.IsNullOrWhiteSpace(seg.Text) && !string.IsNullOrWhiteSpace(seg.Speaker))
            return seg;
        return null;
    }

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "...";

    private static string SegmentRowClass(PodcastSegment seg) => seg.Status switch
    {
        SegStatus.Generating => "seg-active",
        SegStatus.Done => "seg-done",
        SegStatus.Error => "seg-error",
        _ => ""
    };

    private record LogEntry(string Time, string Message, string Level);

    private enum SegStatus { Pending, Generating, Done, Error, Skipped }

    private class PodcastSegment
    {
        public string Number { get; set; } = "";
        public string Speaker { get; set; } = "ryan";
        public string Language { get; set; } = "english";
        public string? Instructions { get; set; }
        public string Text { get; set; } = "";
        public bool Selected { get; set; } = true;
        public SegStatus Status { get; set; } = SegStatus.Pending;
        public double Duration { get; set; }
        public int Retries { get; set; }
    }
}
